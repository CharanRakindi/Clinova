# Server
PORT=5001
HOST=0.0.0.0
NODE_ENV=development

# MongoDB (local, Docker service name, or Atlas)
MONGO_URI=mongodb://127.0.0.1:27017/clinova

# Frontend origin(s) for CORS — comma-separated for multiple
# Dev Vite: http://localhost:5173
# Docker compose (same host via nginx): http://localhost
CLIENT_URL=http://localhost:5173

# JWT — replace with long random secrets before any real deployment
JWT_ACCESS_SECRET=change_me_access_secret_min_32_chars
JWT_REFRESH_SECRET=change_me_refresh_secret_min_32_chars
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# Cookies (optional overrides)
# COOKIE_SECURE=false          # set false for local HTTP Docker
# COOKIE_SAMESITE=lax          # use none + COOKIE_SECURE=true for cross-site HTTPS

# Rate limit (requests per 15 min per IP)
# RATE_LIMIT_MAX=200

# Trust reverse proxy (nginx) — auto-enabled when NODE_ENV=production
# TRUST_PROXY=1

# Seed safety: blocked when NODE_ENV=production unless ALLOW_SEED=true
# ALLOW_SEED=true

# Cloudinary (optional — local disk under server/uploads if unset)
# CLOUDINARY_CLOUD_NAME=your_cloud_name
# CLOUDINARY_API_KEY=your_api_key
# CLOUDINARY_API_SECRET=your_api_secret
