# Server
PORT=5001
NODE_ENV=development

# MongoDB (local or Atlas)
MONGO_URI=mongodb://127.0.0.1:27017/clinova

# Frontend origin for CORS + cookies
CLIENT_URL=http://localhost:5173

# JWT — replace with long random secrets before any real deployment
JWT_ACCESS_SECRET=change_me_access_secret_min_32_chars
JWT_REFRESH_SECRET=change_me_refresh_secret_min_32_chars
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# Seed safety: seeding is blocked when NODE_ENV=production unless ALLOW_SEED=true
# ALLOW_SEED=true

# Cloudinary (optional — uploads use local disk under server/uploads if unset)
# CLOUDINARY_CLOUD_NAME=your_cloud_name
# CLOUDINARY_API_KEY=your_api_key
# CLOUDINARY_API_SECRET=your_api_secret
