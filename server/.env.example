PORT=5000
NODE_ENV=development
MONGO_URI=mongodb://127.0.0.1:27017/medivault
CLIENT_URL=http://localhost:5173
JWT_ACCESS_SECRET=your_super_secret_access_key_change_me
JWT_REFRESH_SECRET=your_super_secret_refresh_key_change_me
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# Cloudinary (Optional — file uploads default to local disk if not set)
# CLOUDINARY_CLOUD_NAME=your_cloud_name
# CLOUDINARY_API_KEY=your_api_key
# CLOUDINARY_API_SECRET=your_api_secret
