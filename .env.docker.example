# Copy to .env.docker and fill in values:
#   cp .env.docker.example .env.docker
#   docker compose --env-file .env.docker up --build -d

# Public URL of the SPA (must match the browser origin for cookies/CORS)
# Local:  http://localhost
# AWS:    http://YOUR_PUBLIC_IP  or  https://app.yourdomain.com
CLIENT_URL=http://localhost

# Host port for the web container
# Local/AWS direct: 80
# Behind Caddy/ALB on the same host: 8080 and reverse-proxy to it
WEB_PORT=80

# REQUIRED — use long random strings in real deployments
JWT_ACCESS_SECRET=replace_with_a_long_random_access_secret_min_32
JWT_REFRESH_SECRET=replace_with_a_long_random_refresh_secret_min_32

ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# HTTP (local or bare EC2 IP): COOKIE_SECURE=false
# HTTPS domain: COOKIE_SECURE=true
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

RATE_LIMIT_MAX=200

# Optional Cloudinary
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
